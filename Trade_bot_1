def now_dt() -> datetime:
    return datetime.now()


def to_float(value: Any) -> Optional[float]:
    if value is None:
        return None
    try:
        return float(value)
    except Exception:
        return None


def clean_text(value: Any) -> Optional[str]:
    if value is None:
        return None
    value = str(value).strip()
    return value if value else None


def market_cap_usd(market_cap_sol: Optional[float]) -> Optional[float]:
    if market_cap_sol is None:
        return None
    return float(market_cap_sol) * float(SOL_USD_PRICE_MANUAL)


def calc_return_percent(current_mc_sol: Optional[float], entry_mc_sol: Optional[float]) -> Optional[float]:
    if current_mc_sol is None or entry_mc_sol is None or entry_mc_sol == 0:
        return None
    return ((current_mc_sol - entry_mc_sol) / entry_mc_sol) * 100


def profit_from_return(return_percent: float) -> float:
    return PAPER_INVESTMENT_EUR * (return_percent / 100.0)


def seconds_label(seconds: int) -> str:
    return f"{seconds // 60}:{seconds % 60:02d}"


