def update_open_trade_metrics(token: TokenState, snapshot: Dict[str, Any], window_seconds: int):
    if not token.paper_entered or token.paper_closed:
        return

    current_mc_sol = snapshot["current_market_cap_sol"]
    current_mc_usd = snapshot["current_market_cap_usd"]
    ret = calc_return_percent(current_mc_sol, token.entry_market_cap_sol)

    if ret is None or current_mc_usd is None:
        return

    if token.best_return_percent is None or ret > token.best_return_percent:
        token.best_return_percent = ret
        token.best_market_cap_usd = current_mc_usd
        token.best_return_seconds = window_seconds

    if token.worst_return_percent is None or ret < token.worst_return_percent:
        token.worst_return_percent = ret
        token.worst_market_cap_usd = current_mc_usd
        token.worst_return_seconds = window_seconds

    if ret >= 15:
        token.hit_plus_15 = True
    if ret >= 20:
        token.hit_plus_20 = True
    if ret >= 30:
        token.hit_plus_30 = True

    if (
        CONFIRMATION_START_SECONDS <= window_seconds <= CONFIRMATION_END_SECONDS
        and not token.confirmed_move
        and ret >= MIN_CONFIRMATION_RETURN_PERCENT
    ):
        token.confirmed_move = True
        token.first_confirmation_seconds = window_seconds
        print("CONFIRMED MOVE:", token.mint, "|", seconds_label(window_seconds), "| return:", round(ret, 2), "%")

    cursor.execute("""
    UPDATE pump_paper_trade_results
    SET
        best_market_cap_usd = %s,
        best_return_percent = %s,
        best_return_seconds = %s,
        worst_market_cap_usd = %s,
        worst_return_percent = %s,
        worst_return_seconds = %s,
        hit_plus_15 = %s,
        hit_plus_20 = %s,
        hit_plus_30 = %s,
        confirmed_move = %s,
        first_confirmation_seconds = %s
    WHERE run_id = %s AND mint = %s
    """, (
        token.best_market_cap_usd, token.best_return_percent, token.best_return_seconds,
        token.worst_market_cap_usd, token.worst_return_percent, token.worst_return_seconds,
        token.hit_plus_15, token.hit_plus_20, token.hit_plus_30,
        token.confirmed_move, token.first_confirmation_seconds,
        RUN_ID, token.mint
    ))
    mydb.commit()


