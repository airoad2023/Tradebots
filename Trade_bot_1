    print()


# =====================================================
# DECISION LOGIC
# =====================================================

def should_close_trade(token: TokenState, snapshot: Dict[str, Any], window_seconds: int) -> Optional[str]:
    if not token.paper_entered or token.paper_closed:
        return None

    ret = calc_return_percent(snapshot["current_market_cap_sol"], token.entry_market_cap_sol)

    if ret is None:
        return None

    # Take profit first.
    if ret >= TAKE_PROFIT_PERCENT:
        return f"TAKE_PROFIT_{TAKE_PROFIT_PERCENT:.0f}%"

    # Stop loss.
    if ret <= STOP_LOSS_PERCENT:
        return f"STOP_LOSS_{abs(STOP_LOSS_PERCENT):.0f}%"

    # No confirmation by 6:30.
    if window_seconds >= CONFIRMATION_END_SECONDS and not token.confirmed_move:
        return "NO_CONFIRMATION_BY_6_30"

    # Force exit at 10:00.
    if window_seconds >= FORCE_EXIT_SECONDS:
        return "FORCE_EXIT_10M"

    return None


# =====================================================
# ASYNC TASKS
# =====================================================

async def token_scheduler(
    websocket,
    token: TokenState,
    tracked: Dict[str, TokenState],
    active_mints: Set[str],
    closed_trade_mints: Set[str],
):
    previous = 0

    for window in DECISION_WINDOWS:
        await asyncio.sleep(max(0, window - previous))

        snapshot = calculate_snapshot(token, window)

        if window == ENTRY_SECONDS:
            if passes_entry_filters(snapshot) and len(closed_trade_mints) + count_open_trades(tracked) < MAX_PAPER_TRADES:
                open_paper_trade(token, snapshot)
            else:
                await unsubscribe_token(websocket, token.mint)
                active_mints.discard(token.mint)
                tracked.pop(token.mint, None)

                mc_usd = snapshot["current_market_cap_usd"] or 0
                print("Rejected at 5m:", token.mint, "| MC USD:", round(mc_usd, 2), "| notes:", snapshot["risk_notes"])
                return

        elif window > ENTRY_SECONDS and token.paper_entered:
            update_open_trade_metrics(token, snapshot, window)
            close_reason = should_close_trade(token, snapshot, window)

            if close_reason:
                close_paper_trade(token, snapshot, window, close_reason)
                closed_trade_mints.add(token.mint)

                await unsubscribe_token(websocket, token.mint)
                active_mints.discard(token.mint)
                tracked.pop(token.mint, None)
                return

        previous = window

    if token.paper_entered and not token.paper_closed:
        final_snapshot = calculate_snapshot(token, FORCE_EXIT_SECONDS)
        close_paper_trade(token, final_snapshot, FORCE_EXIT_SECONDS, "FORCE_EXIT_10M_END")
        closed_trade_mints.add(token.mint)

    await unsubscribe_token(websocket, token.mint)
    active_mints.discard(token.mint)
    tracked.pop(token.mint, None)


def count_open_trades(tracked: Dict[str, TokenState]) -> int:
    return sum(1 for t in tracked.values() if t.paper_entered and not t.paper_closed)


async def unsubscribe_token(websocket, mint: str):
    try:
        await websocket.send(json.dumps({"method": "unsubscribeTokenTrade", "keys": [mint]}))
    except Exception as e:
        print("Unsubscribe error:", mint, e)


