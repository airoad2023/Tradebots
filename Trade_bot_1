    print("Stop-loss trades:", stop_loss)
    print("Success rate profitable:", round(success_rate_profitable, 2), "%")
    print("Success rate take-profit:", round(success_rate_take_profit, 2), "%")
    print("Total paper profit EUR:", round(total_profit, 4))
    print("Average close return:", round(avg_return, 2), "%")
    print("Average best return before close:", round(avg_best, 2), "%")

    cursor.execute("""
    SELECT
        token_name,
        symbol,
        mint,
        entry_market_cap_usd,
        close_market_cap_usd,
        return_percent,
        profit_eur,
        close_reason,
        best_return_percent,
        best_return_seconds,
        confirmed_move,
        entry_creator_sold,
        entry_top_buyer_share_percent,
        entry_net_volume_sol
    FROM pump_paper_trade_results
    WHERE run_id = %s
    ORDER BY id
    """, (RUN_ID,))
    trades = cursor.fetchall()

    print("\nTrades:")
    for t in trades:
        print(
            f"- {t['token_name']} ({t['symbol']}) | "
            f"Return: {round(float(t['return_percent'] or 0), 2)}% | "
            f"Profit EUR: {round(float(t['profit_eur'] or 0), 4)} | "
            f"Reason: {t['close_reason']} | "
            f"Best: {round(float(t['best_return_percent'] or 0), 2)}% at {seconds_label(int(t['best_return_seconds'] or 0))}"
        )


# =====================================================
# MAIN LOOP
# =====================================================

async def run_paper_bot():
    ensure_tables()

    if not PUMPPORTAL_API_KEY or PUMPPORTAL_API_KEY.startswith("PUT_"):
        raise Exception("Add your real PumpPortal API key before running.")

    print("Paper bot started.")
    print("Run ID:", RUN_ID)
    print("Strategy: $10k at 5m -> confirm 5:15-6:30 -> TP +15% / SL -15%")
    print("Max paper trades:", MAX_PAPER_TRADES)
    print("Paper investment per trade:", PAPER_INVESTMENT_EUR, "EUR")

    tracked: Dict[str, TokenState] = {}
    active_mints: Set[str] = set()
    closed_trade_mints: Set[str] = set()

    total_launches = 0
    total_tracked = 0
    paid_trade_messages = 0

    loop = asyncio.get_running_loop()
    start = loop.time()
    launch_end = start + LAUNCH_COLLECTION_SECONDS

    async with websockets.connect(PUMPPORTAL_URL, ping_interval=20, ping_timeout=20) as websocket:
        print("Connected to PumpPortal WebSocket.")

        await websocket.send(json.dumps({"method": "subscribeNewToken"}))
        await websocket.send(json.dumps({"method": "subscribeMigration"}))

        while True:
            now_loop = loop.time()
            launch_window_open = now_loop < launch_end

            # Stop after 5 trades are closed.
            if len(closed_trade_mints) >= MAX_PAPER_TRADES:
                print("Max paper trades closed. Bot will stop.")
                break

            # Stop when launch window ended and no active tokens are left.
            if not launch_window_open and len(active_mints) == 0:
                print("Launch window closed and no active mints left.")
                break

            try:
                raw = await asyncio.wait_for(websocket.recv(), timeout=5)
                data = json.loads(raw)
            except asyncio.TimeoutError:
                continue
            except Exception as e:
                print("WebSocket receive error:", e)
                continue

            if data.get("message"):
                print("Info:", data.get("message"))
                continue

            tx_type = data.get("txType")
            mint = data.get("mint")

            if not mint:
                continue

            if tx_type == "create":
                if not launch_window_open:
                    continue

                total_launches += 1

                if total_tracked >= MAX_TOTAL_TRACKED_TOKENS:
                    continue

                if len(active_mints) >= MAX_ACTIVE_TRACKED_TOKENS:
                    continue

                creator = data.get("traderPublicKey")

                token = TokenState(
                    mint=mint,
                    name=clean_text(data.get("name")),
                    symbol=clean_text(data.get("symbol")),
                    creator_wallet=creator,
                    launch_time=now_dt(),
                    launch_ts=time.time(),
                    initial_market_cap_sol=to_float(data.get("marketCapSol")),
                )

                tracked[mint] = token
                active_mints.add(mint)
                total_tracked += 1

                await websocket.send(json.dumps({"method": "subscribeTokenTrade", "keys": [mint]}))

                asyncio.create_task(token_scheduler(
                    websocket,
                    token,
                    tracked,
                    active_mints,
                    closed_trade_mints
                ))

                print("Tracking:", token.name, "|", token.symbol, "|", mint, "| active:", len(active_mints))

            elif tx_type in ["buy", "sell"]:
                token = tracked.get(mint)
                if not token:
                    continue

                paid_trade_messages += 1

                seconds_after_launch = time.time() - token.launch_ts

                token.trades.append(TradeEvent(
                    tx_type=tx_type,
                    trader=data.get("traderPublicKey"),
                    sol_amount=float(to_float(data.get("solAmount")) or 0),
                    market_cap_sol=to_float(data.get("marketCapSol")),
                    seconds_after_launch=seconds_after_launch,
                    signature=data.get("signature"),
                ))

                if paid_trade_messages % 500 == 0:
                    est_sol = paid_trade_messages * 0.000001
                    print(
                        "Paid messages:", paid_trade_messages,
                        "| estimated SOL:", round(est_sol, 6),
                        "| active:", len(active_mints),
                        "| closed paper trades:", len(closed_trade_mints)
                    )

            else:
                # Migration events are not traded here, but can be logged if needed.
                pass

    print("\nRun finished.")
    print("Total launches seen:", total_launches)
    print("Total tracked:", total_tracked)
    print("Paid trade messages:", paid_trade_messages)
    print("Estimated SOL used:", round(paid_trade_messages * 0.000001, 6))

    print_summary()


if __name__ == "__main__":
    try:
        asyncio.run(run_paper_bot())
    finally:
        try:
            cursor.close()
            mydb.close()
        except Exception:
            pass
