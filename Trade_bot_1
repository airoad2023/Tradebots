# =====================================================
# SNAPSHOT CALCULATION
# =====================================================

def calculate_snapshot(token: TokenState, window_seconds: int) -> Dict[str, Any]:
    relevant = [t for t in token.trades if t.seconds_after_launch <= window_seconds]

    buy_trades = [t for t in relevant if t.tx_type == "buy"]
    sell_trades = [t for t in relevant if t.tx_type == "sell"]

    buy_count = len(buy_trades)
    sell_count = len(sell_trades)

    unique_buyers = len({t.trader for t in buy_trades if t.trader})
    unique_sellers = len({t.trader for t in sell_trades if t.trader})

    buy_volume = sum(t.sol_amount for t in buy_trades)
    sell_volume = sum(t.sol_amount for t in sell_trades)
    net_volume = buy_volume - sell_volume

    # Current MC = latest MC before this snapshot window.
    current_market_cap_sol = token.initial_market_cap_sol
    latest_trade_with_mc = None

    for t in relevant:
        if t.market_cap_sol is not None:
            if latest_trade_with_mc is None or t.seconds_after_launch > latest_trade_with_mc.seconds_after_launch:
                latest_trade_with_mc = t

    if latest_trade_with_mc:
        current_market_cap_sol = latest_trade_with_mc.market_cap_sol

    creator_sell_count = 0
    creator_sell_volume = 0.0

    if token.creator_wallet:
        for t in sell_trades:
            if t.trader == token.creator_wallet:
                creator_sell_count += 1
                creator_sell_volume += t.sol_amount

    creator_sold = creator_sell_count > 0

    # Top buyer share
    buyer_volume_by_wallet: Dict[str, float] = {}
    for t in buy_trades:
        if t.trader:
            buyer_volume_by_wallet[t.trader] = buyer_volume_by_wallet.get(t.trader, 0.0) + t.sol_amount

    top_buyer_sol = max(buyer_volume_by_wallet.values()) if buyer_volume_by_wallet else 0.0
    top_buyer_share = (top_buyer_sol / buy_volume * 100) if buy_volume > 0 else None

    buy_volume_gt_sell_volume = buy_volume > sell_volume
    creator_sell_absorbed = (not creator_sold) or (creator_sold and net_volume > 0 and buy_volume_gt_sell_volume)

    risk_notes = []

    if top_buyer_share is not None and top_buyer_share > MAX_TOP_BUYER_SHARE_PERCENT:
        risk_notes.append("top_buyer_share_too_high")

    if top_buyer_share is not None and top_buyer_share > WARNING_TOP_BUYER_SHARE_PERCENT:
        risk_notes.append("top_buyer_share_warning")

    if creator_sold and not creator_sell_absorbed:
        risk_notes.append("creator_sold_not_absorbed")

    if sell_volume >= buy_volume:
        risk_notes.append("sell_volume_equal_or_higher")

    if net_volume <= 0:
        risk_notes.append("net_volume_not_positive")

    return {
        "window_seconds": window_seconds,
        "current_market_cap_sol": current_market_cap_sol,
        "current_market_cap_usd": market_cap_usd(current_market_cap_sol),
        "buy_count": buy_count,
        "sell_count": sell_count,
        "unique_buyers": unique_buyers,
        "unique_sellers": unique_sellers,
        "buy_volume_sol": buy_volume,
        "sell_volume_sol": sell_volume,
        "net_volume_sol": net_volume,
        "creator_sold": creator_sold,
        "creator_sell_volume_sol": creator_sell_volume,
        "top_buyer_share_percent": top_buyer_share,
        "creator_sell_absorbed": creator_sell_absorbed,
        "risk_notes": ", ".join(risk_notes) if risk_notes else "clean",
    }


def passes_entry_filters(snapshot: Dict[str, Any]) -> bool:
    mc_usd = snapshot["current_market_cap_usd"] or 0

    if mc_usd < ENTRY_MARKET_CAP_USD:
        return False

    top_buyer_share = snapshot["top_buyer_share_percent"]
    if top_buyer_share is not None and top_buyer_share > MAX_TOP_BUYER_SHARE_PERCENT:
        return False

    if snapshot["creator_sold"] and not snapshot["creator_sell_absorbed"]:
        return False

    return True


